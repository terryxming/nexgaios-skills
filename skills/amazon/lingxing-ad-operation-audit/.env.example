# 必填：外部只读 MCP endpoint 和用户 Key。
LINGXING_PUBLIC_MCP_URL=https://mcp.nexgaios.com/mcp-services/lingxing-mcp
LINGXING_REMOTE_MCP_KEY=YOUR_X_MCP_KEY_HERE

# 必填：报告范围。
LINGXING_AD_AUDIT_SID=7481
LINGXING_AD_AUDIT_COUNTRY=US
LINGXING_AD_AUDIT_START_DATE=2026-03-19
LINGXING_AD_AUDIT_END_DATE=2026-06-16

# 可选：广告操作日志筛选条件。
LINGXING_AD_AUDIT_LOG_SOURCE=all
LINGXING_AD_AUDIT_MAX_RECORDS=100000
LINGXING_AD_AUDIT_PAGE_LENGTH=100
LINGXING_AD_AUDIT_OUTPUT=artifacts/lingxing-ad-operation-audit/data/export.json

# 可选：效果层日报导出。
LINGXING_AD_IMPACT_INPUT=artifacts/lingxing-ad-operation-audit/data/export.json
LINGXING_AD_IMPACT_OUTPUT=artifacts/lingxing-ad-operation-audit/data/performance-context.json
LINGXING_AD_IMPACT_WINDOW_DAYS=7
LINGXING_AD_IMPACT_REPORT_TYPES=sp_campaign_reports,sp_keyword_reports
