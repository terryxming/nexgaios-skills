{
  "name": "lingxing-ad-operation-audit",
  "version": "0.1.3",
  "description": "用于生成只读领星广告操作日志 HTML 审计报告的 Codex skill。",
  "type": "module",
  "private": true,
  "scripts": {
    "export:logs": "tsx scripts/export_ad_operation_logs.ts",
    "export:performance": "tsx scripts/export_ad_performance_context.ts",
    "build:report": "python scripts/build_ad_operation_report.py",
    "audit": "powershell -ExecutionPolicy Bypass -File scripts/run_report.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
